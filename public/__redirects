# Redirect all requests to index.html for single-page apps (e.g., React)
# This is useful for handling routes in the frontend
/*    /index.html   200

# Redirect from an old URL to a new one
/old-page    /new-page    301

# Redirect to an external URL
/external    https://example.com    301

# Custom 404 redirect
/404.html    /index.html    404
